/*
  # Security Headers - CloudFlare & Netlify Compatible
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), accelerometer=(), gyroscope=(), magnetometer=(), usb=(), sync-xhr=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com https://fonts.googleapis.com https://d3js.org https://static.cloudflareinsights.com https://challenges.cloudflare.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://unpkg.com https://ipapi.co https://formspree.io https://cloudflareinsights.com https://*.supabase.co https://challenges.cloudflare.com https://api.stripe.com https://api.qrserver.com; frame-src https://challenges.cloudflare.com https://js.stripe.com https://*.github.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests
  X-DNS-Prefetch-Control: on
  X-Permitted-Cross-Domain-Policies: none
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Cache static assets aggressively
/images/*
  Cache-Control: public, max-age=31536000, immutable

/src/css/*
  Cache-Control: public, max-age=31536000, immutable

/src/js/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# HTML pages - cache for short time, revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Sensitive pages must never be cached (contain auth state / PII)
/admin/*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache


/internships/*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache

/dashboard/*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache

/login*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache

/register*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache

/reset-password*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache

/update-password*
  Cache-Control: no-store, no-cache, private
  Pragma: no-cache
